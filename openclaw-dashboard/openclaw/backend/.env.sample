# Copy this to .env and fill in values
PGHOST=your-azure-db-host
PGPORT=5432
PGDATABASE=openclaw
PGUSER=clawuser
PGPASSWORD=secret
PGVECTOR_EXTENSION=true
PGSSL=false

OPENAI_API_KEY=
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_ENABLED=true
EMBED_AGENT_MESSAGES=false
EMBEDDINGS_DIMENSION=1536
MEMORY_AGENT_ID=openclaw:main
OPENCLAW_WORKSPACE=/home/user/.openclaw

# OpenClaw gateway relay
PORT=4000
GATEWAY_URL=http://localhost:18789/v1/responses
GATEWAY_TOKEN=my_token_XXXXXXXXXXXXXXXX
